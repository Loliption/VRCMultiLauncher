<Window
    x:Class="VrcMultiLauncherCS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VrcMultiLauncherCS.Models"
    xmlns:converters="using:VrcMultiLauncherCS.Converters"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Path header -->
        <Border Grid.Row="0"
                Margin="20,20,20,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="12,8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind Loc.ExeLabel, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>

                <TextBox x:Name="PathBox"
                         Grid.Column="1"
                         IsReadOnly="True"
                         PlaceholderText="{x:Bind Loc.ExePlaceholder, Mode=OneWay}"
                         BorderThickness="0"
                         Background="Transparent"/>

                <Button Grid.Column="2"
                        Content="{x:Bind Loc.BrowseBtn, Mode=OneWay}"
                        Click="OnBrowsePath_Click"/>

                <Button Grid.Column="3"
                        Content="{x:Bind Loc.LangToggleBtn, Mode=OneWay}"
                        Click="OnToggleLang_Click"
                        Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="20,0,20,20" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Profile list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="8,8,0,0"
                        Padding="20,8,20,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Loc.ColName, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="ID"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Loc.ColStatus, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="PID"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="OSC"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- List body -->
                <ListView x:Name="ProfileList"
                          Grid.Row="1"
                          SelectionMode="Single"
                          DoubleTapped="ProfileList_DoubleTapped"
                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                          CornerRadius="0,0,8,8"
                          Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Profile">
                            <Grid Padding="12,6" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ProfileId, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Status, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{x:Bind converters:StatusBrush.Get(IsRunning), Mode=OneWay}"/>

                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind PidDisplay, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind OscDisplay, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Sidebar -->
            <StackPanel Grid.Column="1" Spacing="8">

                <!-- Controls -->
                <TextBlock Text="{x:Bind Loc.ControlsLabel, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>

                <Button Content="{x:Bind Loc.LaunchBtn, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnLaunch_Click"/>

                <Button Content="{x:Bind Loc.KillBtn, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        Click="OnKill_Click"/>

                <Border Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="0,12"/>

                <!-- Profile management -->
                <TextBlock Text="{x:Bind Loc.ProfilesLabel, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>

                <Button Content="{x:Bind Loc.NewBtn, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        Click="OnAdd_Click"/>

                <Button Content="{x:Bind Loc.EditBtn, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        Click="OnEdit_Click"/>

                <Button Content="{x:Bind Loc.DeleteBtn, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        Click="OnDelete_Click"/>

                <!-- Status text -->
                <TextBlock x:Name="StatusText"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
